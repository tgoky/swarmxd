# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Solana ────────────────────────────────────────────────────────────────────
# Mainnet via Helius (recommended — set HELIUS_API_KEY below and paste key in URL)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_NETWORK=mainnet-beta

# Devnet fallback (no API key needed, limited rate)
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_WS_URL=wss://api.devnet.solana.com
# SOLANA_NETWORK=devnet

# ── AI (via OpenRouter) ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_MODEL=anthropic/claude-haiku-4

# ── Market data API keys ──────────────────────────────────────────────────────
# Birdeye — aggregates APY + TVL across all Solana DEXs (primary pool data source)
# Get key: https://birdeye.so/developer
BIRDEYE_API_KEY=your-birdeye-api-key-here

# Helius — Solana RPC + DAS API for LP position NFT detection
# Get key: https://www.helius.dev/
HELIUS_API_KEY=your-helius-api-key-here

# ── Swarm ─────────────────────────────────────────────────────────────────────
DRY_RUN=true
LOG_LEVEL=info

# ── Risk controls (optional overrides) ───────────────────────────────────────
# MAX_PORTFOLIO_VALUE_USD=100000
# MAX_TRADE_SIZE_PCT=0.25
# STOP_LOSS_PCT=0.10
# MAX_SLIPPAGE_BPS=100
# HUMAN_APPROVAL_THRESHOLD_USD=5000
# CONSENSUS_THRESHOLD=0.75
# CONDUCTOR_TICK_MS=30000

# ── API Server ────────────────────────────────────────────────────────────────
ADMIN_TOKEN=demo-secret
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000

# ── Dashboard (Next.js public env vars — prefix NEXT_PUBLIC_) ─────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Swarm vault address — users deposit SOL here
# Generate: solana-keygen new --outfile vault.json && solana address -k vault.json
NEXT_PUBLIC_VAULT_ADDRESS=

# API base URL the dashboard talks to
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── On-chain (required for DRY_RUN=false) ────────────────────────────────────
# WALLET_PRIVATE_KEY=[1,2,3,...] — executor wallet as JSON byte array
# Generate: solana-keygen new --outfile vault.json
# Then: WALLET_PRIVATE_KEY=$(cat vault.json)
# SWARM_MEMORY_PROGRAM_ID=...   — deployed Anchor program ID
