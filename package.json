{
  "name": "swarm-conductor",
  "version": "1.0.0",
  "private": true,
  "description": "Autonomous Multi-Agent DeFi Orchestra — Swarm Conductor + Arena + VeriAgent",
  "scripts": {
    "install:all": "pnpm install",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "start:api": "tsx apps/api/src/index.ts",
    "start:conductor": "tsx packages/conductor/src/bootstrap.ts",
    "start:arena": "tsx packages/arena/src/arena-scorer.ts",
    "start:verifier": "tsx packages/veriagent/src/verifier.agent.ts",
    "start:demo": "tsx scripts/demo.ts",
    "start:all": "concurrently -n api,conductor,arena,verifier -c cyan,green,yellow,magenta \"pnpm start:api\" \"pnpm start:conductor\" \"pnpm start:arena\" \"pnpm start:verifier\"",
    "dashboard:open": "open apps/dashboard/public/index.html || xdg-open apps/dashboard/public/index.html",
    "docker:up": "docker compose up -d",
    "docker:logs": "docker compose logs -f",
    "docker:down": "docker compose down",
    "chain:build": "cd packages/on-chain && anchor build",
    "chain:deploy": "cd packages/on-chain && anchor deploy",
    "chain:test": "cd packages/on-chain && anchor test",
    "demo": "tsx scripts/demo.ts"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "vitest": "^1.5.0",
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
