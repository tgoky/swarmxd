# ─── LLM ─────────────────────────────────────────────────────────────────────
# Use OpenRouter (recommended — works with Claude, GPT-4, etc.)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OR use Anthropic directly (comment out OPENROUTER_API_KEY if using this)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use — OpenRouter format: "anthropic/claude-sonnet-4"
# Full list at https://openrouter.ai/models
# Cheap fast option:  anthropic/claude-haiku-4
# Balanced option:    anthropic/claude-sonnet-4    ← recommended
# Most capable:       anthropic/claude-opus-4
LLM_MODEL=anthropic/claude-sonnet-4

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Solana ───────────────────────────────────────────────────────────────────
# Use devnet for demo (free, no real funds needed)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Your Solana wallet — leave empty when DRY_RUN=true
WALLET_PRIVATE_KEY=
WALLET_PUBLIC_KEY=

# Deployed Anchor program ID (leave empty to skip on-chain logging)
SWARM_MEMORY_PROGRAM_ID=

# ─── Risk controls ────────────────────────────────────────────────────────────
MAX_PORTFOLIO_VALUE_USD=10000
MAX_TRADE_SIZE_PCT=0.25
STOP_LOSS_PCT=0.10
MAX_SLIPPAGE_BPS=100
HUMAN_APPROVAL_THRESHOLD_USD=1000

# ─── Conductor ────────────────────────────────────────────────────────────────
CONDUCTOR_TICK_MS=30000
CONSENSUS_THRESHOLD=0.75
AGENT_TIMEOUT_MS=15000

# DRY_RUN=true  → simulate everything, no real txns (use this for demo)
# DRY_RUN=false → real Solana transactions (needs wallet + funds)
DRY_RUN=true

# ─── API server ───────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000
ADMIN_TOKEN=change-me-before-prod

# ─── Arena ────────────────────────────────────────────────────────────────────
ARENA_TICK_MS=10000
SWARM_ID=my-swarm

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
