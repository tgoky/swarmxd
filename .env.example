# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.testnet.solana.com
SOLANA_WS_URL=wss://api.testnet.solana.com
SOLANA_NETWORK=testnet

# ── AI (via OpenRouter) ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_MODEL=anthropic/claude-haiku-4

# ── Swarm ─────────────────────────────────────────────────────────────────────
DRY_RUN=true
LOG_LEVEL=info

# ── API Server ────────────────────────────────────────────────────────────────
ADMIN_TOKEN=demo-secret
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000

# ── Dashboard (Next.js public env vars — prefix NEXT_PUBLIC_) ─────────────────
# Solana RPC for the browser wallet connection
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.testnet.solana.com

# Swarm vault address on testnet — users deposit SOL here
# Generate one with: solana-keygen new --outfile vault.json && solana address -k vault.json
NEXT_PUBLIC_VAULT_ADDRESS=

# API base URL the dashboard talks to
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Executor wallet (platform-side — NEVER share with users) ─────────────────
# This is the platform's trading wallet. Users deposit SOL to its public address.
# The swarm trades with those funds on their behalf.
#
# One-time setup:
#   solana-keygen new --outfile vault.json --no-bip39-passphrase
#   WALLET_PRIVATE_KEY=$(cat vault.json)                         ← paste below
#   NEXT_PUBLIC_VAULT_ADDRESS=$(solana address -k vault.json)    ← paste in dashboard section
#   solana airdrop 2 $(solana address -k vault.json) --url testnet
#
WALLET_PRIVATE_KEY=

# ── On-chain audit trail (optional — only needed for on-chain memory logging) ──
# SWARM_MEMORY_PROGRAM_ID=...   — deployed Anchor program ID
